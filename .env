# ============================================================
# CREDENTIALS FILE
# Fill in your own API keys below.
# Never share this file or push it to GitHub.
# Add .env to your .gitignore file.
# ============================================================

# --- OpenAI ---
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY="Your_api_key"

# --- Pinecone ---
# Get this from: https://app.pinecone.io/
PINECONE_API_KEY="Your_Pinecone_API_Key"

# The name you want to give your Pinecone index
PINECONE_INDEX_NAME="supportagent"

# Pinecone cloud and region (free tier default)
PINECONE_CLOUD="aws"
PINECONE_REGION="us-east-1"
